# ── 3D Print Monitor — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Home Assistant ─────────────────────────────────────────────────────────────
HA_CAMERA_IMAGE_URL=https://your-ha-instance/api/image_proxy/image.your_camera
HA_LONG_LIVED_TOKEN=your_home_assistant_long_lived_token
HA_WEBHOOK_URL=https://your-ha-instance:8123/api/webhook/your_webhook_id

# ── YOLOv8n model (fast, always-on detection) ──────────────────────────────────
# Path to your trained best.pt — or use the included model: ./best.pt
YOLO_MODEL_PATH=./best.pt
# Confidence thresholds (0.0–1.0) — tune to reduce false positives
YOLO_STOP_CONF=0.65
YOLO_WARN_CONF=0.35

# ── Vision server (Ollama) — only used by /describe ────────────────────────────
VISION_SERVER_IP=192.168.1.x
VISION_SERVER_PORT=11434
# Recommended model — run: ollama pull llava:7b-v1.6
VISION_MODEL_NAME=llava:7b-v1.6

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Monitoring behaviour ───────────────────────────────────────────────────────
POLL_INTERVAL_FAST_SECONDS=20
POLL_INTERVAL_SLOW_SECONDS=120
FAST_PHASE_DURATION_SECONDS=1800
EMPTY_TIMEOUT_SECONDS=3600
WARN_COOLDOWN_SECONDS=600
STOP_CONFIRM_COUNT=2
WARN_ESCALATE_COUNT=5
NETWORK_LISTENER_PORT=65432
